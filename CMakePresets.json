{
	"version": 6,
	"configurePresets": [
		{
			"name": "base",
			"hidden": true,
			"binaryDir": "${sourceDir}/build/${presetName}",
			"cacheVariables": {
				"CMAKE_TOOLCHAIN_FILE": "./vcpkg/scripts/buildsystems/vcpkg.cmake"
			}
		},
		{
			"name": "linux-base",
			"inherits": "base",
			"hidden": true,
			"cacheVariables": {
				"VCPKG_TARGET_TRIPLET": "x64-linux"
			}
		},
		{
			"name": "ninja-debug-linux",
			"inherits": "linux-base",
			"generator": "Ninja",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug"
			}
		},
		{
			"name": "ninja-release-linux",
			"inherits": "linux-base",
			"generator": "Ninja",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release"
			}
		},
		{
			"name": "windows-base",
			"inherits": "base",
			"hidden": true,
			"cacheVariables": {
				"VCPKG_TARGET_TRIPLET": "x64-windows"
			}
		},
		{
			"name": "msvc",
			"inherits": "windows-base",
			"generator": "Visual Studio 17 2022"
		}
	],
	"buildPresets": [
		{
			"name": "ninja-debug-linux",
			"configurePreset": "ninja-debug-linux"
		},
		{
			"name": "ninja-release-linux",
			"configurePreset": "ninja-release-linux"
		}
	],
	"workflowPresets": [
		{
			"name": "ninja-debug-linux",
			"steps": [
				{
					"type": "configure",
					"name": "ninja-debug-linux"
				},
				{
					"type": "build",
					"name": "ninja-debug-linux"
				}
			]
		},
		{
			"name": "ninja-release-linux",
			"steps": [
				{
					"type": "configure",
					"name": "ninja-release-linux"
				},
				{
					"type": "build",
					"name": "ninja-release-linux"
				}
			]
		},
		{
			"name": "generate-sln",
			"steps": [
				{
					"type": "configure",
					"name": "msvc"
				}
			]
		}
	]
}
